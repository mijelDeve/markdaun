{
  "git": {
    "tagName": "v${version}",
    "push": false,
    "requireUpstream": false
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "angular",
      "infile": "CHANGELOG.md"
    }
  },
  "github": {
    "release": true,
    "autoGenerate": true
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "before:init": "npm run build"
  }
}
