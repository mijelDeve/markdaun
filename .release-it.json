{
  "git": {
    "tagName": "v${version}"
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "angular",
      "infile": "CHANGELOG.md"
    }
  },
  "github": {
    "release": true,
    "autoGenerate": true
  },
  "npm": {
    "publish": false,
    "version": "${version}"
  },
  "hooks": {
    "before:init": "npm run build"
  },
  "increment": false
}
